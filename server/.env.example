PORT=5000

# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Comma-separated allowed CORS origins (leave empty to allow all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# PayPal (sandbox or live)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# OpenAI — used for Whisper transcription and GPT-4o-mini analysis
OPENAI_API_KEY=sk-...

# Python Pose Service base URL
POSE_SERVICE_URL=http://localhost:8000

# Google Calendar integration (optional but recommended for appointment invite emails)
# Use a Google service account with calendar write access.
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Calendar ID to store appointments (example: primary or shared-team-calendar@group.calendar.google.com)
GOOGLE_CALENDAR_ID=primary
# Optional: user to impersonate if your Workspace uses domain-wide delegation
GOOGLE_IMPERSONATED_USER=
# Appointment event settings
APPOINTMENT_TIMEZONE=Asia/Kolkata
APPOINTMENT_DURATION_MINUTES=30
# If true, appointment creation fails unless Google Calendar event creation succeeds
CALENDAR_SYNC_REQUIRED=false
# Health check endpoint: GET /health/calendar validates config/auth and write access
