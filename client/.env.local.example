# Backend URL (shared Express server in /server)
#
# IMPORTANT: Use your machine's LOCAL NETWORK IP, not localhost.
# localhost/127.0.0.1 refers to the device itself on a physical phone.
# Run `ipconfig` (Windows) or `ifconfig` (Mac/Linux) to find your IP.
#
# Example: http://192.168.1.42:5000
#
# For Android EMULATOR only you can use: http://10.0.2.2:5000
# For iOS simulator on the same Mac you can use: http://localhost:5000
EXPO_PUBLIC_API_URL=http://<YOUR_LOCAL_IP>:5000

# Python Pose Service WebSocket URL
# Same IP rule applies
EXPO_PUBLIC_POSE_WS_URL=ws://<YOUR_LOCAL_IP>:8000/stream
